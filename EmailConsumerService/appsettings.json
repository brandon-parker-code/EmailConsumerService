{
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "Topic": "email-requests",
    "GroupId": "email-consumer-service",
    "AutoOffsetReset": "Earliest",
    "EnableIdempotence": true,
    "Acks": "All",
    "CompressionType": "Gzip",
    "MessageTimeoutMs": 10000
  },
  "SendGrid": {
    "ApiKey": "my-api-key",
    "DefaultFromEmail": "noreply@example.com",
    "DefaultFromName": "Email Consumer Service"
  },
  "Smtp": {
    "Host": "smtp.example.com",
    "Port": 587,
    "Username": "",
    "Password": "",
    "EnableSsl": true,
    "DefaultFromEmail": "noreply@example.com",
    "DefaultFromName": "Email Consumer Service"
  },
  "Database": {
    "ConnectionString": "Server=localhost;Database=EmailDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "C:\\logs\\email-consumer-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
